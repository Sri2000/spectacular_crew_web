# ============================================================
# Database Configuration
# ============================================================
# SQLite (default — no setup needed)
DATABASE_URL=sqlite:///./retail_simulator.db
# MySQL (optional)
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/retail_simulator

# ============================================================
# Application
# ============================================================
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# ============================================================
# API
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================
# Performance SLA
# ============================================================
RISK_PROCESSING_SLA_SECONDS=300
SIMULATION_SLA_SECONDS=30
UI_RESPONSE_SLA_SECONDS=2

# ============================================================
# Google Gemini — AI reasoning engine
# ============================================================
# Get your free API key at: https://aistudio.google.com/apikey
# Add your real key in .env — NEVER commit .env to git

GEMINI_API_KEY=your_google_ai_studio_key_here

# ----------------------------------------------------------
# Model selection — change this ONE line to switch models
# ----------------------------------------------------------
# Recommended options:
GEMINI_MODEL_ID=gemini-2.0-flash

# Deep reasoning (higher cost, better quality):
# GEMINI_MODEL_ID=gemini-1.5-pro

# Fast and cost-efficient:
# GEMINI_MODEL_ID=gemini-1.5-flash
